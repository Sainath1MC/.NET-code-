name: Verify Production Secrets and Variables

on:
  workflow_dispatch:
    inputs:
      branch:
description: 'Branch to deploy (feature-verification / develop / qa / main)'
        required: true
        type: string


jobs:
  verify:
    runs-on: ubuntu-latest

    steps:
      - name: Display Variable
        run: |
          echo "Application Name: ${{ vars.PRODUCTION_APPLICATION_NAME }}"

      - name: Verify Secrets
        env:
          TENANT_ID: ${{ secrets.PROD_AZURE_TENANT_ID }}
          CLIENT_ID: ${{ secrets.PROD_AZURE_CLIENT_ID }}
          SUBSCRIPTION_ID: ${{ secrets.PROD_AZURE_SUBSCRIPTION_ID }}
        shell: bash
        run: |
          echo "Tenant ID Length: ${#TENANT_ID}"
          echo "Tenant ID Ends With: ${TENANT_ID: -4}"

          echo "Client ID Length: ${#CLIENT_ID}"
          echo "Client ID Ends With: ${CLIENT_ID: -4}"

          echo "Subscription ID Length: ${#SUBSCRIPTION_ID}"
          echo "Subscription ID Ends With: ${SUBSCRIPTION_ID: -4}"
